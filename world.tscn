[sub_resource type="GDScript" id="GDScript_26xuy"]
script/source = "extends Node

var shark := preload(\"res://Animals/3/shark.tscn\")
var tertule := preload(\"res://Animals/2/tertle.tscn\")
var jelly := preload(\"res://Animals/1/jelly.tscn\")

@onready var marker_2d: Marker2D = $Marker2D
@onready var marker_2d_2: Marker2D = $Marker2D2
@onready var marker_2d_3: Marker2D = $Marker2D3
@onready var marker_2d_4: Marker2D = $Marker2D4
@onready var marker_2d_5: Marker2D = $Marker2D5
@onready var marker_2d_6: Marker2D = $Marker2D6
@onready var marker_2d_7: Marker2D = $Marker2D7
@onready var marker_2d_8: Marker2D = $Marker2D8

@export var turtle_count := 10
@export var shark_count := 6
@export var jelly_count := 8

var spawn_points := []

func _ready() -> void:

	randomize()

	spawn_points = [
		marker_2d,
		marker_2d_2,
		marker_2d_3,
		marker_2d_4,
		marker_2d_5,
		marker_2d_6,
		marker_2d_7,
		marker_2d_8
	]

	spawn_mobs()


func spawn_mobs() -> void:

	for i in turtle_count:
		spawn_mob(tertule)

	for i in shark_count:
		spawn_mob(shark)

	for i in jelly_count:
		spawn_mob(jelly)


func spawn_mob(scene: PackedScene) -> void:

	var mob = scene.instantiate()

	var point = spawn_points.pick_random()

	mob.global_position = point.global_position

	get_parent().add_child.call_deferred(mob)
"

