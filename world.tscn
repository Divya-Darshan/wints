[sub_resource type="GDScript" id="GDScript_wukud"]
script/source = "extends Node2D

@onready var color_rect: ColorRect = $CanvasLayer/ColorRect


func _ready() -> void:
	color_rect.modulate.a = 1.0

	var tween = create_tween()
	tween.tween_property(color_rect, \"modulate:a\", 0.0, 0.5)
"

[sub_resource type="GDScript" id="GDScript_gbfbk"]
script/source = "extends Sprite2D

@export var speed: float = 3.0
@export var travel_distance: float = 2306.0

var start_x: float

func _ready() -> void:
	start_x = position.x

func _process(delta: float) -> void:
	position.x = move_toward(position.x, position.x - speed, speed * delta)

	if start_x - position.x >= travel_distance:
		position.x = start_x
"

[sub_resource type="WorldBoundaryShape2D" id="WorldBoundaryShape2D_k3n1d"]

